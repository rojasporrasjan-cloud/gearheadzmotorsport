# ─────────────────────────────────────────────────
# STRIPE API KEYS
# Get these from: dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────

# Secret key — only used on the server, NEVER expose this in frontend code
# Starts with sk_live_... (production) or sk_test_... (testing)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

# ─────────────────────────────────────────────────
# SITE URL
# Your deployed URL on Vercel (no trailing slash)
# Example: https://gearheadzmotorsports.vercel.app
# ─────────────────────────────────────────────────
SITE_URL=https://your-site.vercel.app

# ─────────────────────────────────────────────────
# STRIPE WEBHOOK SECRET
# Used to verify events sent to /api/webhook
# Starts with whsec_...
# ─────────────────────────────────────────────────
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# ─────────────────────────────────────────────────
# FIREBASE ADMIN SERVICE ACCOUNT
# Base64 encoded JSON string
# Used by Vercel serverless functions to access Firestore
# ─────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT=base64_encoded_json_here
